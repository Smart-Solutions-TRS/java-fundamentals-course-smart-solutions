public class Estudiante {

    String nombre;
    int edad;
    int nota;

    Estudiante(String nombre, int edad, int nota) {
        this.nombre = nombre;
        this.edad = edad;
        this.nota = nota;
    }

    void mostrarInfo() {
        System.out.println("Nombre: " + nombre);
        System.out.println("Edad: " + edad);
        System.out.println("Nota: " + nota);
        System.out.println("---");
    }

    public static void main(String[] args) {
        Estudiante e1 = new Estudiante("Ana", 15, 18);
        Estudiante e2 = new Estudiante("Luis", 14, 12);

        e1.mostrarInfo();
        e2.mostrarInfo();
    }
}
